# Staging-Umgebung Konfiguration
# Kopieren nach .env.staging und Werte anpassen

# Datenbank
DB_NAME=roots_staging
DB_USER=postgres
DB_PASSWORD=sicheres-passwort-hier

# JWT
JWT_SECRET=staging-jwt-secret-hier-aendern
JWT_EXPIRES_IN=7d

# CORS (Deine Staging-Domain oder Server-IP:8080)
CORS_ORIGIN=http://DEINE-SERVER-IP:8080

# Frontend API URL (leer lassen wenn nginx als Proxy genutzt wird)
VITE_API_URL=
